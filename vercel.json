{
  "builds": [
    { 
      "src": "package.json", 
      "use": "@vercel/static-build",
      "config": { "distDir": "frontend/dist" }
    },
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}